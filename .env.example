# --- LLM keys ---
# Gemini via Google AI Studio (https://aistudio.google.com/apikey) — used by the ADK agent
GOOGLE_API_KEY=

# Anthropic — used by the ACR classifier (src/critcom/classification/classifier.py)
ANTHROPIC_API_KEY=

# --- CritCom auth (Prompt Opinion -> agent) ---
CRITCOM_API_KEY=dev-key-please-change
# Optional second valid key for rotation
CRITCOM_API_KEY_SECONDARY=
# Set to "false" to disable X-API-Key enforcement (local dev only)
CRITCOM_REQUIRE_API_KEY=true

# --- Agent runtime ---
CRITCOM_LLM_MODEL=gemini-2.0-flash
CRITCOM_LLM_MAX_TOKENS=1024
CRITCOM_LLM_TEMPERATURE=0.0
CRITCOM_AGENT_URL=http://localhost:8001
CRITCOM_FHIR_EXTENSION_URI=https://promptopinion.ai/schemas/a2a/v1/fhir-context
LOG_LEVEL=INFO

# --- FHIR (HAPI) ---
CRITCOM_FHIR_BASE_URL=http://localhost:8080/fhir
CRITCOM_FHIR_BEARER_TOKEN=
CRITCOM_FHIR_TIMEOUT_SECONDS=10
CRITCOM_FHIR_MAX_RETRIES=3

# --- DICOM (Orthanc) ---
CRITCOM_DICOM_HOST=localhost
CRITCOM_DICOM_PORT=4242
CRITCOM_DICOM_AET=ORTHANC
CRITCOM_DICOM_CALLING_AET=CRITCOM
CRITCOM_ORTHANC_URL=http://localhost:8042
CRITCOM_ORTHANC_USER=orthanc
CRITCOM_ORTHANC_PASSWORD=orthanc
CRITCOM_DICOM_WORKLIST_DIR=./orthanc-worklists

# --- ACR ack timeouts (minutes) ---
CRITCOM_CAT1_ACK_TIMEOUT_MINUTES=60
CRITCOM_CAT2_ACK_TIMEOUT_MINUTES=1440
CRITCOM_CAT1_ESCALATION_LEVELS=2
CRITCOM_CAT2_ESCALATION_LEVELS=1