# ── LLM ───────────────────────────────────────────────────────────────────────
# Claude Sonnet 4.5 via Anthropic API (routed through LiteLLM inside Google ADK).
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
CRITCOM_LLM_MODEL=anthropic/claude-sonnet-4-5
CRITCOM_LLM_TEMPERATURE=0.0
CRITCOM_LLM_MAX_TOKENS=1024

# ── FHIR ──────────────────────────────────────────────────────────────────────
# Local HAPI FHIR R4 (docker compose up -d fhir).
CRITCOM_FHIR_BASE_URL=http://localhost:8080/fhir
CRITCOM_FHIR_BEARER_TOKEN=
CRITCOM_FHIR_TIMEOUT_SECONDS=10
CRITCOM_FHIR_MAX_RETRIES=3

# ── Escalation thresholds (ACR-inspired defaults; see CLAUDE.md §State Machine) ─
CRITCOM_CAT1_ACK_TIMEOUT_MINUTES=60
CRITCOM_CAT1_ESCALATION_LEVELS=2
CRITCOM_CAT2_ACK_TIMEOUT_MINUTES=1440
CRITCOM_CAT2_ESCALATION_LEVELS=1

# ── Logging ───────────────────────────────────────────────────────────────────
CRITCOM_LOG_LEVEL=INFO
CRITCOM_LOG_FORMAT=json

# ── A2A / Prompt Opinion (platform integration — filled in later tasks) ───────
PO_PLATFORM_BASE_URL=
CRITCOM_AGENT_API_KEY=
